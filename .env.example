POSTGRES_DB=zeroon
POSTGRES_USER=zeroon
# Development defaults below are intentionally rejected when the prod profile is active.
POSTGRES_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me
ZEROON_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-bytes
ZEROON_ACCESS_TOKEN_TTL_MINUTES=30
ZEROON_REFRESH_TOKEN_TTL_DAYS=30
ZEROON_LOCAL_VERIFICATION_CODE=000000
ZEROON_VERIFICATION_CODE_TTL_MINUTES=10
ZEROON_VERIFICATION_CODE_REQUEST_COOLDOWN_SECONDS=60
ZEROON_VERIFICATION_CODE_MOBILE_HOURLY_LIMIT=5
ZEROON_VERIFICATION_CODE_IP_HOURLY_LIMIT=20
ZEROON_VERIFICATION_CODE_DEVICE_LOGIN_LIMIT=10
ZEROON_VERIFICATION_CODE_IP_LOGIN_LIMIT=30
ZEROON_VERIFICATION_CODE_LOGIN_WINDOW_MINUTES=15
ZEROON_VERIFICATION_CODE_MAX_FAILED_ATTEMPTS=5
ZEROON_VERIFICATION_CODE_SENDER_URL=
ZEROON_VERIFICATION_CODE_SENDER_TOKEN=
LLM_API_KEY=
LLM_BASE_URL=
ZEROON_LLM_PROVIDER=openai-compatible
ZEROON_LLM_MODEL=gpt-4o-mini
ZEROON_LLM_TIMEOUT_SECONDS=10

# Production launch checklist:
# - set SPRING_PROFILES_ACTIVE=prod
# - replace POSTGRES_PASSWORD with at least 12 non-placeholder characters
# - replace ZEROON_ACCESS_TOKEN_SECRET with at least 32 random characters
# - point REDIS_HOST at shared Redis and replace REDIS_PASSWORD with at least 12 characters
# - configure an HTTPS ZEROON_VERIFICATION_CODE_SENDER_URL and sender token
# - terminate untrusted forwarded headers at the edge before enabling native proxy headers
